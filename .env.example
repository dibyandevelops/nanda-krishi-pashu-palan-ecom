# Neon PostgreSQL
DATABASE_URL=postgresql://YOUR_NEON_USER:YOUR_NEON_PASSWORD@YOUR_NEON_HOST/YOUR_DB?sslmode=require&channel_binding=require

# Session signing key (use a long random string in production)
AUTH_SECRET=change-this-to-a-long-random-secret

# Public site URL for success/failure redirect pages
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# eSewa form URL
# Sandbox: https://rc-epay.esewa.com.np/api/epay/main/v2/form
# Production: https://epay.esewa.com.np/api/epay/main/v2/form
NEXT_PUBLIC_ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form

# eSewa merchant product code and secret key
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# eSewa transaction verification endpoint
# Sandbox: https://rc-epay.esewa.com.np/api/epay/transaction/status/
# Production: https://epay.esewa.com.np/api/epay/transaction/status/
ESEWA_STATUS_CHECK_URL=https://rc-epay.esewa.com.np/api/epay/transaction/status/
